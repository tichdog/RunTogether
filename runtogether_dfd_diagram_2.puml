@startuml
title DFD: потоки данных web-приложения RunTogether

left to right direction

actor "Гость" as Guest
actor "Участник" as Member
actor "Организатор" as Organizer
actor "Администратор" as Admin
actor "Планировщик\nфоновых задач" as Scheduler

rectangle "Клиентская часть\nReact Frontend" as Frontend

rectangle "Backend API\nNext.js" {
  rectangle "Авторизация\nи сессии" as AuthProcess
  rectangle "Профили\nи пользователи" as UsersProcess
  rectangle "Тренировки,\nзаявки и участие" as WorkoutProcess
  rectangle "Отзывы,\nдостижения и уведомления" as SocialProcess
  rectangle "Жалобы,\nмодерация и админка" as AdminProcess
  rectangle "Фоновые задачи:\nстатусы, напоминания, очистка" as JobsProcess
}

database "Пользователи и доступ\nusers\nauth_sessions" as UserData
database "Тренировочный процесс\nworkouts\nworkout_participants\nactivity_feed" as WorkoutData
database "Социальные данные\nreviews\nachievements\nuser_achievements\nnotifications" as SocialData
database "Модерация и настройки\nreports\nuser_warnings\nsystem_settings" as AdminData

Guest --> Frontend : регистрация\nвход в систему
Member --> Frontend : поиск тренировок\nзаявки, профиль,\nотзывы, жалобы
Organizer --> Frontend : создание тренировок\nрешения по заявкам\nуправление участниками
Admin --> Frontend : управление пользователями\nжалобы, роли, настройки
Scheduler --> JobsProcess : периодический запуск

Frontend --> AuthProcess : login, register,\nrefresh, logout, me
AuthProcess --> UserData : создать пользователя,\nпроверить пароль,\nроль и статус аккаунта,\nсоздать/обновить сессию
UserData --> AuthProcess : данные пользователя,\nроль, account_status,\nсостояние сессии
AuthProcess --> Frontend : результат входа,\nhttpOnly cookie,\nданные пользователя или ошибка

Frontend --> UsersProcess : открыть/изменить профиль,\nзагрузить аватар,\nоткрыть профиль другого пользователя
UsersProcess --> UserData : профиль, приватность,\nтелефон, email, аватар
UsersProcess --> WorkoutData : история организованных\nи посещенных тренировок
UsersProcess --> SocialData : рейтинг, отзывы,\nдостижения
UsersProcess --> AdminData : количество жалоб\nи предупреждений
UsersProcess --> Frontend : профиль,\nстатистика,\nистория, достижения

Frontend --> WorkoutProcess : список тренировок,\nфильтры, карточка,\nсоздание, изменение,\nотмена тренировки,\nподача и обработка заявок
WorkoutProcess --> WorkoutData : workouts:\nopen, full, in_progress,\ncompleted, archived, cancelled\n\nworkout_participants:\npending, confirmed,\ndeclined, cancelled
WorkoutData --> WorkoutProcess : тренировки,\nучастники, лимит мест,\nстатус заявки пользователя
WorkoutProcess --> UserData : организатор,\nучастники,\nправа владельца или админа
WorkoutProcess --> AdminData : настройки создания:\nлимит участников,\nминимальное время до старта
WorkoutProcess --> SocialData : уведомления об изменении,\nотмене, заявке или решении
WorkoutProcess --> Frontend : список/карточка тренировки,\nрезультат заявки,\nошибка или подтверждение

Frontend --> SocialProcess : получить уведомления,\nотметить прочитанным,\nоставить отзыв,\nпосмотреть достижения
SocialProcess --> SocialData : notifications read_at,\nreviews,\nachievements,\nuser_achievements
SocialData --> SocialProcess : уведомления,\nцели для оценки,\nотзывы, достижения
SocialProcess --> WorkoutData : проверка завершенной тренировки\nи подтвержденных участников
SocialProcess --> UserData : автор отзыва\nи получатель оценки
SocialProcess --> Frontend : уведомления,\nформа отзыва,\nсохраненный отзыв,\nсписок достижений

Frontend --> AdminProcess : список пользователей,\nсмена роли,\nблокировка,\nсписок жалоб,\nрешение по жалобе,\nнастройки системы,\nCRUD достижений
AdminProcess --> UserData : роли,\nстатус аккаунта,\nблокировка пользователя
AdminProcess --> AdminData : reports:\nopen, warned,\nbanned, dismissed\n\nsystem_settings
AdminProcess --> WorkoutData : админ-просмотр\nи отмена тренировок
AdminProcess --> SocialData : уведомления о модерации,\nсоздание/изменение/удаление достижений
AdminProcess --> Frontend : административные списки,\nстатус жалобы,\nрезультат изменений

JobsProcess --> WorkoutData : синхронизация статусов:\nopen/full -> in_progress\nin_progress -> completed\ncompleted -> archived
JobsProcess --> SocialData : напоминания о тренировке,\nочистка старых уведомлений,\nначисление достижений
JobsProcess --> AdminData : сроки хранения,\nокно отзывов,\nнастройки cron-задач

@enduml
