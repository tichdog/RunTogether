{
  "name": "sport-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 4000",
    "dev:logs": "next dev -p 4000 | pino-pretty --translateTime SYS:standard --ignore pid,hostname",
    "postinstall": "prisma generate",
    "db:up": "docker compose --profile database up -d postgres",
    "db:down": "docker compose stop postgres",
    "observability:up": "docker compose up -d loki promtail grafana",
    "observability:down": "docker compose stop loki promtail grafana",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"src/**/*.js\" \"middleware.js\" \"next.config.mjs\" \"eslint.config.js\" \"jsconfig.json\" \"package.json\" \"docker-compose.yml\" \"README.md\" --write --config ../.prettierrc --ignore-path ../.prettierignore",
    "format:check": "prettier \"src/**/*.js\" \"middleware.js\" \"next.config.mjs\" \"eslint.config.js\" \"jsconfig.json\" \"package.json\" \"docker-compose.yml\" \"README.md\" --check --config ../.prettierrc --ignore-path ../.prettierignore",
    "prisma:generate": "prisma generate",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "db:schema": "prisma db execute --file src/db/schema.sql --schema prisma/schema.prisma",
    "db:seed": "prisma db execute --file src/db/seed.sql --schema prisma/schema.prisma",
    "check": "next build"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "next": "^16.2.6",
    "pino": "^10.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "overrides": {
    "postcss": "^8.5.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0"
  }
}
