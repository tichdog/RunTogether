{
  "name": "sport-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"src/**/*.js\" \"middleware.js\" \"next.config.mjs\" \"eslint.config.js\" \"jsconfig.json\" \"package.json\" \"docker-compose.yml\" \"README.md\" --write --config ../.prettierrc --ignore-path ../.prettierignore",
    "format:check": "prettier \"src/**/*.js\" \"middleware.js\" \"next.config.mjs\" \"eslint.config.js\" \"jsconfig.json\" \"package.json\" \"docker-compose.yml\" \"README.md\" --check --config ../.prettierrc --ignore-path ../.prettierignore",
    "db:schema": "psql \"$DATABASE_URL\" -f src/db/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f src/db/seed.sql",
    "check": "next build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "next": "^16.2.6",
    "pg": "^8.13.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "overrides": {
    "postcss": "^8.5.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  }
}
