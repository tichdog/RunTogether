NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174
DATABASE_URL=postgres://postgres:postgres@localhost:5433/sport_training
JWT_SECRET=change-this-jwt-secret-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
ACCESS_COOKIE_NAME=sport_access_token
REFRESH_COOKIE_NAME=sport_refresh_token
ACCESS_COOKIE_MAX_AGE_SECONDS=900
REFRESH_COOKIE_MAX_AGE_SECONDS=2592000
LOG_LEVEL=info
LOG_FILE=logs/backend.log
UPLOAD_DIR=public/uploads
MAX_UPLOAD_BYTES=3145728
CRON_SECRET=change-this-cron-secret-at-least-32-characters
CRON_URL=http://localhost:4000/api/cron/workouts
CRON_INTERVAL_MS=3600000
# Official Cloudflare Turnstile dummy key for localhost. Replace it in production.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
